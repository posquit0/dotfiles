# Shell integration features.
# INFO: `ghostty +show-config --default --docs` for all options.

# ssh-terminfo: install Ghostty's terminfo on the remote host on SSH, so `TERM=xterm-ghostty` is recognized (fixes `tput: unknown terminal` and doubled input when sshing without tmux).
# ssh-env: fall back to a safe TERM when terminfo can't be installed.
shell-integration-features = ssh-env,ssh-terminfo
